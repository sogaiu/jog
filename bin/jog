(defn z/down
  ``
  Moves down the tree, returning the leftmost child z-location of
  `zloc`, or nil if there are no children.
  ``
  [zloc]
  (when (z/branch? zloc)
    (let [[node st] zloc
          [k rest-kids kids]
          (s/first-rest-maybe-all (z/children zloc))]
      (when kids
        [k
         (z/make-state zloc
                       []
                       rest-kids
                       (if (not (empty? st))
                         (s/tuple-push (st :pnodes) node)
                         [node])
                       st
                       (st :changed?))]))))

(comment

  (z/node (z/down (z/zip [:a :b [:x :y]])))
  # =>
  :a

  (-> (z/zip [:a :b [:x :y]])
      z/down
      z/branch?)
  # =>
  false

  (try
    (-> (z/zip [:a])
        z/down
        z/children)
    ([e] e))
  # =>
  "Called `children` on a non-branch zloc"

  (deep=
    #
    (merge {}
           (-> [:a [:b [:x :y]]]
               z/zip
               z/down
               z/state))
    #
    '@{:ls ()
       :pnodes ((:a (:b (:x :y))))
       :pstate @{}
       :rs ((:b (:x :y)))})
  # =>
  true

  )

(defn z/right
  ``
  Returns the z-location of the right sibling of the node
  at `zloc`, or nil if there is no such sibling.
  ``
  [zloc]
  (let [[node st] zloc
        {:ls ls :rs rs} st
        [r rest-rs rs] (s/first-rest-maybe-all rs)]
    (when (and (not (empty? st)) rs)
      [r
       (z/make-state zloc
                     (s/tuple-push ls node)
                     rest-rs
                     (st :pnodes)
                     (st :pstate)
                     (st :changed?))])))

(comment

  (-> (z/zip [:a :b])
      z/down
      z/right
      z/node)
  # =>
  :b

  (-> (z/zip [:a])
      z/down
      z/right)
  # =>
  nil

  )

(defn z/make-node
  ``
  Returns a branch node, given `zloc`, `node` and `children`.
  ``
  [zloc node children]
  (((z/state zloc) :make-node) node children))

(comment

  (z/make-node (z/zip [:a :b [:x :y]])
               [:a :b] [:x :y])
  # =>
  [:x :y]

  )

(defn z/up
  ``
  Moves up the tree, returning the parent z-location of `zloc`,
  or nil if at the root z-location.
  ``
  [zloc]
  (let [[node st] zloc
        {:ls ls
         :pnodes pnodes
         :pstate pstate
         :rs rs
         :changed? changed?} st]
    (when pnodes
      (let [pnode (last pnodes)]
        (if changed?
          [(z/make-node zloc pnode [;ls node ;rs])
           (z/make-state zloc
                         (pstate :ls)
                         (pstate :rs)
                         (pstate :pnodes)
                         (pstate :pstate)
                         true)]
          [pnode pstate])))))

(comment

  (def z/m-zip
    (z/zip [:a :b [:x :y]]))

  (deep=
    (-> z/m-zip
        z/down
        z/up)
    z/m-zip)
  # =>
  true

  (deep=
    (-> z/m-zip
        z/down
        z/right
        z/right
        z/down
        z/up
        z/up)
    z/m-zip)
  # =>
  true

  )

# XXX: used by `root` and `df-next`
(defn z/end?
  "Returns true if `zloc` represents the end of a depth-first walk."
  [zloc]
  (= :end (z/state zloc)))

(defn z/root
  ``
  Moves all the way up the tree for `zloc` and returns the node at
  the root z-location.
  ``
  [zloc]
  (if (z/end? zloc)
    (z/node zloc)
    (if-let [p (z/up zloc)]
      (z/root p)
      (z/node zloc))))

(comment

  (def z/a-zip
    (z/zip [:a :b [:x :y]]))

  (z/node z/a-zip)
  # =>
  (-> z/a-zip
      z/down
      z/right
      z/right
      z/down
      z/root)

  )

(defn z/df-next
  ``
  Moves to the next z-location, depth-first.  When the end is
  reached, returns a special z-location detectable via `end?`.
  Does not move if already at the end.
  ``
  [zloc]
  #
  (defn recur
    [loc]
    (if (z/up loc)
      (or (z/right (z/up loc))
          (recur (z/up loc)))
      [(z/node loc) :end]))
  #
  (if (z/end? zloc)
    zloc
    (or (and (z/branch? zloc) (z/down zloc))
        (z/right zloc)
        (recur zloc))))

(comment

  (def z/a-zip
    (z/zip [:a :b [:x]]))

  (z/node (z/df-next z/a-zip))
  # =>
  :a

  (-> z/a-zip
      z/df-next
      z/df-next
      z/node)
  # =>
  :b

  (-> z/a-zip
      z/df-next
      z/df-next
      z/df-next
      z/df-next
      z/df-next
      z/end?)
  # =>
  true

  )

(defn z/replace
  "Replaces existing node at `zloc` with `node`, without moving."
  [zloc node]
  (let [[_ st] zloc]
    [node
     (z/make-state zloc
                   (st :ls)
                   (st :rs)
                   (st :pnodes)
                   (st :pstate)
                   true)]))

(comment

  (-> (z/zip [:a :b [:x :y]])
      z/down
      (z/replace :w)
      z/root)
  # =>
  [:w :b [:x :y]]

  (-> (z/zip [:a :b [:x :y]])
      z/down
      z/right
      z/right
      z/down
      (z/replace :w)
      z/root)
  # =>
  [:a :b [:w :y]]

  )

(defn z/edit
  ``
  Replaces the node at `zloc` with the value of `(f node args)`,
   where `node` is the node associated with `zloc`.
  ``
  [zloc f & args]
  (z/replace zloc
             (apply f (z/node zloc) args)))

