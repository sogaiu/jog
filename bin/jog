(defn z/rightmost
  ``
  Returns the z-location of the rightmost sibling of the node at
  `zloc`, or the current node's z-location if there are none to the
  right.
  ``
  [zloc]
  (let [[node st] zloc
        {:ls ls :rs rs} st]
    (if (and (not (empty? st))
             (indexed? rs)
             (not (empty? rs)))
      [(last rs)
       (z/make-state zloc
                     (s/tuple-push ls node ;(s/butlast rs))
                     []
                     (st :pnodes)
                     (st :pstate)
                     (st :changed?))]
      zloc)))

(comment

  (-> (z/zip [:a :b [:x :y]])
      z/down
      z/rightmost
      z/node)
  # =>
  [:x :y]

  )

(defn z/remove
  ``
  Removes the node at `zloc`, returning the z-location that would have
  preceded it in a depth-first walk.
  Throws an error if called at the root z-location.
  ``
  [zloc]
  (let [[node st] zloc
        {:ls ls
         :pnodes pnodes
         :pstate pstate
         :rs rs} st]
    #
    (defn recur
      [a-zloc]
      (if-let [child (and (z/branch? a-zloc) (z/down a-zloc))]
        (recur (z/rightmost child))
        a-zloc))
    #
    (if (not (empty? st))
      (if (pos? (length ls))
        (recur [(last ls)
                (z/make-state zloc
                              (s/butlast ls)
                              rs
                              pnodes
                              pstate
                              true)])
        [(z/make-node zloc (last pnodes) rs)
         (z/make-state zloc
                       (pstate :ls)
                       (pstate :rs)
                       (pstate :pnodes)
                       (pstate :pstate)
                       true)])
      (error "Called `remove` at root"))))

(comment

  (-> (z/zip [:a :b [:x :y]])
      z/down
      z/right
      z/remove
      z/node)
  # =>
  :a

  (try
    (z/remove (z/zip [:a :b [:x :y]]))
    ([e] e))
  # =>
  "Called `remove` at root"

  )

