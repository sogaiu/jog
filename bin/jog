                         :b
                         true))
      z/left
      z/node)
  # =>
  :a

  (-> (z/zip [:b :a :b])
      z/down
      (z/search-after |(match (z/node $)
                         :d
                         true)))
  # =>
  nil

  (-> (z/zip [:a [:b :c [2 [3 :smile] 5]]])
      (z/search-after |(match (z/node $)
                         [_ :smile]
                         true))
      z/down
