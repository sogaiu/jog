(defn z/search-from
  ``
  Successively call `pred` on z-locations starting at `zloc`
  in depth-first order.  If a call to `pred` returns a
  truthy value, return the corresponding z-location.
  Otherwise, return nil.
  ``
  [zloc pred]
  (if (pred zloc)
    zloc
    (when-let [next-zloc (z/df-next zloc)]
      (when (z/end? next-zloc)
        (break nil))
      (z/search-from next-zloc pred))))

(comment

  (-> (z/zip [:a :b :c])
      z/down
      (z/search-from |(match (z/node $)
                        :b
                        true))
      z/node)
  # =>
  :b

  (-> (z/zip [:a :b :c])
      z/down
      (z/search-from |(match (z/node $)
                        :d
                        true)))
  # =>
  nil

  (-> (z/zip [:a :b :c])
      z/down
      (z/search-from |(match (z/node $)
                        :a
                        true))
      z/node)
  # =>
  :a

  )

(defn z/search-after
  ``
  Successively call `pred` on z-locations starting after
  `zloc` in depth-first order.  If a call to `pred` returns a
  truthy value, return the corresponding z-location.
  Otherwise, return nil.
  ``
  [zloc pred]
  (when (z/end? zloc)
    (break nil))
  (when-let [next-zloc (z/df-next zloc)]
    (if (pred next-zloc)
      next-zloc
      (z/search-after next-zloc pred))))

(comment

  (-> (z/zip [:b :a :b])
