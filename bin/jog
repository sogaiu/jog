        "  idiom `(as-macro ,my-custom-macro arg1 arg2...)` can be used\n"
        "  to avoid unwanted variable capture of `my-custom-macro`.``")
      :params-str "[f & args]"}]

  (f/find-doc-of
    ``
    (def smile "a docstring" 1)

    (defn smile
      "I am a docstring."
      [y]
      (pp y))
    ``
    {:name "smile"})
  # =>
  @[@{:bc 12 :bl 1
      :def-type "def"
      :found-name "smile"
      :text `"a docstring"`}
    @{:bc 3 :bl 4
      :def-type "defn"
      :found-name "smile"
      :text `"I am a docstring."`
      :params-str "[y]"}]

