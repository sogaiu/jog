#(import ./location :as l)
#(import ./zipper :as z)

(defn z/has-children?
  ``
  Returns true if `node` can have children.
  Returns false if `node` cannot have children.
  ``
  [a-node]
  (when-let [[head] a-node]
    (truthy? (get {:code true
                   :fn true
                   :quasiquote true
                   :quote true
                   :splice true
                   :unquote true
                   :array true
                   :tuple true
                   :bracket-array true
                   :bracket-tuple true
                   :table true
                   :struct true}
                  head))))

(comment

  (z/has-children?
    [:tuple @{}
     [:symbol @{} "+"] [:whitespace @{} " "]
     [:number @{} "1"] [:whitespace @{} " "]
     [:number @{} "2"]])
  # =>
  true

  (z/has-children? [:number @{} "8"])
  # =>
  false

  )

(defn z/zip
  ``
  Returns a zipper location (zloc or z-location) for a tree
  representing Janet code.
  ``
  [tree]
  (defn branch?
    [a-node]
    (truthy? (and (indexed? a-node)
                  (not (empty? a-node))
                  (z/has-children? a-node))))
  #
  (defn children
    [a-node]
    (if (branch? a-node)
      (slice a-node 2)
      (error "Called `children` on a non-branch node")))
  #
  (defn make-node
    [a-node children]
    [(first a-node) @{} ;children])
  #
  (z/zipper tree
            :branch? branch?
            :children children
            :make-node make-node))

(comment

  (def z/root-node
    @[:code @{} [:number @{} "8"]])

  (def [z/the-node z/the-state]
    (z/zip z/root-node))

  z/the-node
  # =>
  z/root-node

  (merge {} z/the-state)
  # =>
  @{}

  )

(defn z/attrs
  ``
  Return the attributes table for the node of a z-location.  The
  attributes table contains at least bounds of the node by 1-based line
  and column numbers.
  ``
  [zloc]
  (get (z/node zloc) 1))

(comment

  (-> (l/par "(+ 1 3)")
      z/zip
      z/down
      z/attrs)
  # =>
  @{:bc 1 :bl 1 :ec 8 :el 1}

  )

(defn z/zip-down
  ``
  Convenience function that returns a zipper which has
  already had `down` called on it.
  ``
  [tree]
  (-> (z/zip tree)
      z/down))

(comment

  (-> (l/par "(+ 1 3)")
      z/zip-down
      z/node)
  # =>
  '(:tuple @{:bc 1 :bl 1
             :ec 8 :el 1}
           (:symbol @{:bc 2 :bl 1
                      :ec 3 :el 1} "+")
           (:whitespace @{:bc 3 :bl 1
                          :ec 4 :el 1} " ")
           (:number @{:bc 4 :bl 1
                      :ec 5 :el 1} "1")
           (:whitespace @{:bc 5 :bl 1
                          :ec 6 :el 1} " ")
           (:number @{:bc 6 :bl 1
                      :ec 7 :el 1} "3"))

  )

# wsc == whitespace, comment
(defn z/right-skip-wsc
  ``
  Try to move right from `zloc`, skipping over whitespace
  and comment nodes.

  When at least one right move succeeds, return the z-location
  for the last successful right move destination.  Otherwise,
  return nil.
  ``
  [zloc]
  (z/right-until zloc
                 |(match (z/node $)
                    [:whitespace]
                    false
                    #
                    [:comment]
                    false
                    #
                    true)))

(comment

  (-> (l/par
        ``
        (# hi there
        + 1 2)
        ``)
      z/zip-down
      z/down
      z/right-skip-wsc
      z/node)
  # =>
  [:symbol @{:bc 1 :bl 2 :ec 2 :el 2} "+"]

  (-> (l/par "(:a)")
      z/zip-down
      z/down
      z/right-skip-wsc)
  # =>
  nil

  )

(defn z/left-skip-wsc
  ``
  Try to move left from `zloc`, skipping over whitespace
  and comment nodes.

  When at least one left move succeeds, return the z-location
  for the last successful left move destination.  Otherwise,
  return nil.
  ``
  [zloc]
  (z/left-until zloc
                |(match (z/node $)
                   [:whitespace]
                   false
                   #
                   [:comment]
                   false
                   #
                   true)))

(comment

  (-> (l/par
        ``
        (# hi there
        + 1 2)
        ``)
      z/zip-down
      z/down
      z/right-skip-wsc
      z/right-skip-wsc
      z/left-skip-wsc
      z/node)
  # =>
  [:symbol @{:bc 1 :bl 2 :ec 2 :el 2} "+"]

  (-> (l/par "(:a)")
      z/zip-down
      z/down
      z/left-skip-wsc)
  # =>
  nil

  )

